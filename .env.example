# Docker external network name (must be created manually)
DOCKER_LAN_NETWORK=image_analyzer_lan

# Static container IPs inside your LAN subnet
BACKEND_STATIC_IP=192.168.1.220
DB_STATIC_IP=192.168.1.221
FRONTEND_STATIC_IP=192.168.1.222

# Host-access port (for same laptop testing)
FRONTEND_HOST_PORT=8088

# PostgreSQL
POSTGRES_DB=image_analyzer
POSTGRES_USER=image_user
POSTGRES_PASSWORD=change_me_strong_password

# Gemini
GEMINI_API_KEY=replace_with_real_api_key
GEMINI_MODEL=gemini-1.5-flash
